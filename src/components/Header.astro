---
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container">
    <a href="/" class="logo">
      <span class="logo-icon">&#9733;</span>
      Site Confiance SEO
    </a>
    <nav>
      <a href="/" class:list={[{ active: currentPath === '/' }]}>Accueil</a>
      <a href="/blog/" class:list={[{ active: currentPath.startsWith('/blog') }]}>Blog</a>
      <a href="/agences/" class:list={[{ active: currentPath.startsWith('/agences') }]}>Agences & Avis</a>
    </nav>
  </div>
</header>

<style>
  .header {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .logo {
    font-weight: 700;
    font-size: 1.15rem;
    color: #1e3a5f;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .logo-icon {
    color: #22c55e;
    font-size: 1.4rem;
  }
  nav {
    display: flex;
    gap: 1.5rem;
  }
  nav a {
    color: #4b5563;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  nav a:hover,
  nav a.active {
    color: #1e3a5f;
  }
</style>
