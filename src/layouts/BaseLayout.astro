---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  jsonLd?: object;
}

const { title, description, ogType, jsonLd } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <SEOHead title={title} description={description} ogType={ogType} jsonLd={jsonLd} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
